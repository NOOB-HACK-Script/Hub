    adminBtn.BackgroundColor3 = Color3.fromRGB(0, 100, 0)
end)

espBtn.MouseButton1Click:Connect(function()
    _G.Toggles.ESP = not _G.Toggles.ESP
    espBtn.Text = _G.Toggles.ESP and "ESP NPC: ON" or "ESP NPC: OFF"
    espBtn.BackgroundColor3 = _G.Toggles.ESP and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(55, 55, 55)
    
    if not _G.Toggles.ESP then
        for _, v in pairs(ws:GetDescendants()) do
            if v.Name == "NPCHighlight" then v:Destroy() end
        end
    end
end)

speedBtn.MouseButton1Click:Connect(function()
    _G.Toggles.Speed = not _G.Toggles.Speed
    speedBtn.Text = _G.Toggles.Speed and "Speed Hack: ON" or "Speed Hack: OFF"
    speedBtn.BackgroundColor3 = _G.Toggles.Speed and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(55, 55, 55)
end)

ammoBtn.MouseButton1Click:Connect(function()
    pcall(function()
        for _, v in pairs(getgc(true)) do
            if type(v) == "table" and rawget(v, "Ammo") then
                v.Ammo = 9999; v.StoredAmmo = 99999
            end
        end
    end)
    ammoBtn.Text = "Dome!(if not work click again)"
    task.wait(1)
    ammoBtn.Text = "Infinite Ammo(Xeno Unsupported)"
end)

interactBtn.MouseButton1Click:Connect(function()
    _G.Toggles.Interact = not _G.Toggles.Interact
    interactBtn.Text = _G.Toggles.Interact and "Instant Interact: ON" or "Instant Interact: OFF"
    interactBtn.BackgroundColor3 = _G.Toggles.Interact and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(55, 55, 55)
end)

local dragging = false
sliderDot.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local mousePos = UserInputService:GetMouseLocation().X
        local relativePos = math.clamp((mousePos - sliderBar.AbsolutePosition.X) / sliderBar.AbsoluteSize.X, 0, 1)
        sliderDot.Position = UDim2.new(relativePos, -7, 0.5, -7)
        _G.Config.speed = math.floor(16 + (relativePos * 84))
        sliderLabel.Text = "Speed Value: " .. tostring(_G.Config.speed)
    end
end)

RunService.Heartbeat:Connect(function()
    local char = lplr.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if hum then
        if _G.Toggles.Speed then
            local shift = UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) or UserInputService:IsKeyDown(Enum.KeyCode.RightShift)
            hum.WalkSpeed = shift and 16 or _G.Config.speed
        else
            if hum.WalkSpeed ~= 16 then hum.WalkSpeed = 16 end
        end
    end
end)

task.spawn(function()
    while true do
        if _G.Toggles.ESP then
            for _, obj in pairs(ws:GetChildren()) do
                if obj:IsA("Model") and obj:FindFirstChild("Humanoid") and not Players:GetPlayerFromCharacter(obj) then
                    if obj.Humanoid.Health > 0 then
                        local hl = obj:FindFirstChild("NPCHighlight") or Instance.new("Highlight", obj)
                        hl.Name = "NPCHighlight"
                        hl.FillColor = Color3.fromRGB(255, 0, 0)
                        hl.Enabled = true
                    elseif obj:FindFirstChild("NPCHighlight") then
                        obj.NPCHighlight:Destroy()
                    end
                end
            end
        end
        task.wait(_G.Config.scanRate)
    end
end)

ProximityPromptService.PromptShown:Connect(function(prompt)
    if _G.Toggles.Interact then prompt.HoldDuration = 0 end
end)

local dragHub, dragStart, startPos
TopBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragHub = true; dragStart = input.Position; startPos = MainFrame.Position
        input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragHub = false end end)
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragHub and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
