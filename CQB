_G.ESPActive = false

local function UpdateEsp(model, state)
    if Players:GetPlayerFromCharacter(model) then return end

    local hl = model:FindFirstChild("NPCHighlight")
    if state then
        if not hl then
            hl = Instance.new("Highlight")
            hl.Name = "NPCHighlight"
            hl.FillColor = Color3.fromRGB(255, 0, 0)
            hl.FillTransparency = 0.5
            hl.Parent = model
        end
        hl.Enabled = true
    elseif hl then
        hl.Enabled = false
    end

    local bgui = model:FindFirstChild("NPCHealthBar")
    if state then
        if not bgui then
            local head = model:WaitForChild("Head", 5)
            local hum = model:FindFirstChild("Humanoid")
            if head and hum then
                bgui = Instance.new("BillboardGui", model)
                bgui.Name = "NPCHealthBar"
                bgui.Adornee = head
                bgui.Size = UDim2.new(0, 40, 0, 4)
                bgui.ExtentsOffset = Vector3.new(0, 2.5, 0)
                bgui.AlwaysOnTop = true
                
                local bar = Instance.new("Frame", bgui)
                bar.Size = UDim2.new(hum.Health/hum.MaxHealth, 0, 1, 0)
                bar.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
                bar.BorderSizePixel = 0
                
                hum.HealthChanged:Connect(function()
                    bar:TweenSize(UDim2.new(math.clamp(hum.Health/hum.MaxHealth, 0, 1), 0, 1, 0), "Out", "Quad", 0.2, true)
                end)
            end
        end
        if bgui then bgui.Enabled = true end
    elseif bgui then
        bgui.Enabled = false
    end
end

ammoBtn.MouseButton1Click:Connect(function()
    pcall(function()
        for _, v in pairs(getgc(true)) do
            if type(v) == "table" and rawget(v, "Ammo") and rawget(v, "StoredAmmo") then
                v.Ammo = 9999
                v.StoredAmmo = 9999999
            end
        end
    end)
    ammoBtn.Text = "If not work click again"
    task.wait(1)
    ammoBtn.Text = "Infinite Ammo"
end)

espBtn.MouseButton1Click:Connect(function()
    _G.ESPActive = not _G.ESPActive
    
    if _G.ESPActive then
        espBtn.Text = "ESP NPC: ON"
        espBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
    else
        espBtn.Text = "ESP NPC: OFF"
        espBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    end

    for _, v in pairs(Workspace:GetDescendants()) do
        if v:IsA("Model") and v:FindFirstChild("Humanoid") then
            UpdateEsp(v, _G.ESPActive)
        end
    end
end)

Workspace.DescendantAdded:Connect(function(v)
    if v:IsA("Model") then
        task.wait(0.5)
        if v:FindFirstChild("Humanoid") then UpdateEsp(v, _G.ESPActive) end
    end
end)

local dragging, dragInput, dragStart, startPos
local function update(input)
    local delta = input.Position - dragStart
    MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end

TopBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then dragging = false end
        end)
    end
end)

TopBar.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then update(input) end
end)
